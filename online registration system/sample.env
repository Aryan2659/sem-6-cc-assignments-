# ============================================================
#  .env — Server environment variables
#  Place this file inside the /server folder
#  NEVER commit this file to GitHub (it's in .gitignore)
# ============================================================

# Your MongoDB Atlas connection string (get this from Step 3 in README)
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/eventregistration?retryWrites=true&w=majority

# Port the backend server runs on
PORT=5000
